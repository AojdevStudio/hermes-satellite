#!/usr/bin/env bash
# hst — hermes-satellite observability CLI.
# Read-only views over the async bridge's SQLite state and logs.
# Zero deps beyond bash + sqlite3. Install: symlink into a PATH dir
# (optionally twice, as both `hst` and `hermes-satellite`).
set -euo pipefail

HERMES_HOME="${HERMES_HOME:-$HOME/.hermes}"
DB="${HERMES_ASYNC_BRIDGE_DB:-$HERMES_HOME/async_bridge.db}"
LOG_DIR="${HERMES_ASYNC_BRIDGE_LOG_DIR:-$HOME/Library/Logs}"
TRANSCRIPT_DIR="${HERMES_ASYNC_BRIDGE_TRANSCRIPT_DIR:-/tmp/hermes-async-bridge-transcripts}"

# Colors: on for TTY stdout, off when piped or NO_COLOR is set.
if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
  RED=$'\e[31m'; GRN=$'\e[32m'; YLW=$'\e[33m'; CYN=$'\e[36m'
  BLD=$'\e[1m'; DIM=$'\e[2m'; RST=$'\e[0m'
else
  RED=""; GRN=""; YLW=""; CYN=""; BLD=""; DIM=""; RST=""
fi

# Colorize status/event words and de-emphasize table header rules.
paint() {
  sed -E \
    -e "s/(^|[[:space:]])(running)([[:space:]]|$)/\1${YLW}\2${RST}\3/g" \
    -e "s/(^|[[:space:]])(pending|submit|status|respond)([[:space:]]|$)/\1${CYN}\2${RST}\3/g" \
    -e "s/(^|[[:space:]])(completed|result)([[:space:]]|$)/\1${GRN}\2${RST}\3/g" \
    -e "s/(^|[[:space:]])(failed|cancelled|error)([[:space:]]|$)/\1${RED}\2${RST}\3/g" \
    -e "s/^([-[:space:]]{8,})$/${DIM}\1${RST}/"
}

hdr() { printf '%s\n' "${BLD}${RED}── $* ──${RST}"; }

usage() {
  cat <<EOF
${BLD}hst${RST} ${DIM}—${RST} ${RED}hermes-satellite${RST} bridge observability

${BLD}Usage:${RST} hst <command> [args]

  ${BLD}tasks${RST} [-n N] [-s STATUS]   Recent tasks (id, status, profile, caller, age, prompt)
  ${BLD}task${RST} <id-prefix>           Everything about one task: row, runs, costs, events, result
  ${BLD}watch${RST} [id-prefix]          Stream status/event changes until terminal (no id: whole bridge)
  ${BLD}events${RST} [-n N] [id-prefix]  Bridge MCP event log, optionally for one task
  ${BLD}costs${RST} [-n N]               Cost snapshots joined to tasks
  ${BLD}transcript${RST} <id-prefix>     Export the task's Hermes session transcript (JSONL), print its path
  ${BLD}logs${RST} [-f]                  Bridge process logs (-f to follow)
  ${BLD}health${RST}                     Service, port, and DB counts at a glance

${DIM}All output is read-only. DB: \$HERMES_ASYNC_BRIDGE_DB or ~/.hermes/async_bridge.db.
Colors: TTY only; set NO_COLOR=1 to disable.${RST}
EOF
}

die() { echo "hst: $*" >&2; exit 1; }
[ -r "$DB" ] || { [ "${1:-}" = "logs" ] || [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ] || [ $# -eq 0 ] || die "bridge db not readable: $DB"; }

# ponytail: plain open, not -readonly — the CLI can't readonly-open this WAL db
# while the bridge holds it; every query below is a SELECT.
q() { sqlite3 "$DB" "$@"; }
qcol() { sqlite3 -column -header "$DB" "$@"; }

resolve_task() {
  local ids n
  ids=$(q "SELECT task_id FROM tasks WHERE task_id LIKE '$1%';")
  n=$(echo "$ids" | grep -c . 2>/dev/null || echo 0)
  [ "$n" = "1" ] || die "task prefix '$1' matches $n tasks$([ "$n" != 0 ] && echo $'\n'"$ids")"
  echo "$ids"
}

cmd="${1:-}"; shift || true
case "$cmd" in
  tasks)
    n=20; status=""
    while getopts "n:s:" o; do case $o in n) n=$OPTARG;; s) status=$OPTARG;; *) exit 2;; esac; done
    where=""; [ -n "$status" ] && where="WHERE status='$status'"
    qcol "SELECT substr(task_id,1,8) AS id, status, COALESCE(profile,'default') AS profile,
                 COALESCE(NULLIF(caller,''),'-') AS caller,
                 CAST((strftime('%s','now')-created_at)/60 AS INT)||'m' AS age,
                 substr(replace(prompt,char(10),' '),1,60) AS prompt
          FROM tasks $where ORDER BY created_at DESC LIMIT $n;" | paint
    ;;
  task)
    [ $# -ge 1 ] || die "usage: hst task <id-prefix>"
    id=$(resolve_task "$1")
    hdr task
    qcol "SELECT task_id, status, COALESCE(profile,'default') AS profile, caller, session_id, parent_task_id,
                 datetime(created_at,'unixepoch','localtime') AS created,
                 datetime(completed_at,'unixepoch','localtime') AS completed
          FROM tasks WHERE task_id='$id';" | paint
    echo; hdr prompt; q "SELECT prompt FROM tasks WHERE task_id='$id';"
    echo; hdr runs
    qcol "SELECT loop_index, pid, exit_code, CAST(completed_at-started_at AS INT)||'s' AS dur
          FROM task_runs WHERE task_id='$id' ORDER BY loop_index;"
    echo; hdr costs
    qcol "SELECT * FROM task_costs WHERE task_id='$id';" 2>/dev/null || true
    echo; hdr events
    qcol "SELECT datetime(ts,'unixepoch','localtime') AS at, event_type FROM mcp_events WHERE task_id='$id' ORDER BY ts;" | paint
    echo; hdr result
    q "SELECT COALESCE(result, '(error) '||COALESCE(error,'none')) FROM tasks WHERE task_id='$id';"
    fu=$(q "SELECT followups FROM tasks WHERE task_id='$id';")
    [ "$fu" != "[]" ] && { echo; hdr followups; echo "$fu"; }
    ;;
  watch)
    # ponytail: 5s poll over sqlite, not a real event stream — the bridge has
    # no pubsub; upgrade path is tailing mcp_events by rowid, which is what
    # this does. Ctrl-C to stop; exits on terminal status when watching one task.
    id=""; [ $# -ge 1 ] && id=$(resolve_task "$1")
    last=$(q "SELECT COALESCE(MAX(id),0) FROM mcp_events;")
    [ -n "$id" ] && echo "watching $id (poll 5s, Ctrl-C to stop)" || echo "watching all bridge events (poll 5s, Ctrl-C to stop)"
    while :; do
      where="id > $last"; [ -n "$id" ] && where="$where AND task_id='$id'"
      sqlite3 -column "$DB" "SELECT datetime(ts,'unixepoch','localtime'), event_type,
                                    COALESCE(substr(task_id,1,8),'-') FROM mcp_events WHERE $where ORDER BY id;" | paint
      last=$(q "SELECT COALESCE(MAX(id),$last) FROM mcp_events;")
      if [ -n "$id" ]; then
        st=$(q "SELECT status FROM tasks WHERE task_id='$id';")
        case "$st" in completed|failed|cancelled)
          hdr "terminal: $st" | paint
          q "SELECT substr(COALESCE(result, '(error) '||COALESCE(error,'')),1,2000) FROM tasks WHERE task_id='$id';"
          exit 0;;
        esac
      fi
      sleep 5
    done
    ;;
  events)
    n=30; while getopts "n:" o; do case $o in n) n=$OPTARG;; *) exit 2;; esac; done
    shift $((OPTIND-1)) || true
    where=""; [ $# -ge 1 ] && where="WHERE task_id LIKE '$1%'"
    qcol "SELECT datetime(ts,'unixepoch','localtime') AS at, event_type,
                 COALESCE(substr(task_id,1,8),'-') AS task, COALESCE(NULLIF(caller,''),'-') AS caller
          FROM mcp_events $where ORDER BY ts DESC LIMIT $n;" | paint
    ;;
  costs)
    n=10; while getopts "n:" o; do case $o in n) n=$OPTARG;; *) exit 2;; esac; done
    qcol "SELECT substr(c.task_id,1,8) AS id, c.* FROM task_costs c
          ORDER BY c.id DESC LIMIT $n;" 2>/dev/null || echo "(no task_costs rows)"
    ;;
  transcript)
    [ $# -ge 1 ] || die "usage: hst transcript <id-prefix>"
    id=$(resolve_task "$1")
    sid=$(q "SELECT session_id FROM tasks WHERE task_id='$id';")
    [ -n "$sid" ] || die "task $id has no session_id (never started?)"
    profile=$(q "SELECT COALESCE(profile,'') FROM tasks WHERE task_id='$id';")
    mkdir -p "$TRANSCRIPT_DIR"
    out="$TRANSCRIPT_DIR/hst-$id.jsonl"
    if [ -n "$profile" ]; then hermes -p "$profile" sessions export "$out" --session-id "$sid" >/dev/null
    else hermes sessions export "$out" --session-id "$sid" >/dev/null; fi
    echo "$out"
    ;;
  logs)
    log="$LOG_DIR/hermes-async-bridge.log"; err="$LOG_DIR/hermes-async-bridge.err.log"
    if [ "${1:-}" = "-f" ]; then tail -f "$log" "$err"; else tail -n 40 "$log" "$err"; fi
    ;;
  health)
    printf "service: "; launchctl list 2>/dev/null | grep hermes-async-bridge || echo "(not loaded)"
    printf "port:    "; (lsof -nP -iTCP:"${HERMES_ASYNC_BRIDGE_PORT:-8081}" -sTCP:LISTEN 2>/dev/null | tail -1) || echo "(nothing listening)"
    echo "db:      $DB"
    qcol "SELECT status, COUNT(*) AS n FROM tasks GROUP BY status ORDER BY n DESC;" | paint
    qcol "SELECT COUNT(*) AS events_24h FROM mcp_events WHERE ts > strftime('%s','now')-86400;"
    ;;
  -h|--help|"") usage ;;
  *) die "unknown command: $cmd (try --help)" ;;
esac
